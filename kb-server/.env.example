# Path to the canonical vault directory (must be a Git repo)
VAULT_PATH=/Users/yashturkar/Downloads/flightdeck/vault

# Postgres connection
DATABASE_URL=postgresql://kb:kb@localhost:5432/kb

# API key — every request must include X-API-Key header when set.
# Leave blank to disable auth (development only).
KB_API_KEY=

# Git
GIT_REMOTE=origin
GIT_BRANCH=main
GIT_PUSH_ENABLED=true

# Autosave
AUTOSAVE_DEBOUNCE_SECONDS=30

# Revup stacked-diff PR workflow
REVUP_BASE_BRANCH=main
REVUP_TOPIC_PREFIX=kb-api
REVUP_BATCH_DEBOUNCE_SECONDS=10

# Quartz publishing (set one or both; leave blank to disable)
QUARTZ_BUILD_COMMAND=
QUARTZ_WEBHOOK_URL=

# API
API_HOST=0.0.0.0
API_PORT=8000
