[Unit]
Description=KB Server API
After=network.target postgresql.service

[Service]
Type=simple
User=kb
WorkingDirectory=/opt/kb-server
EnvironmentFile=/opt/kb-server/.env
ExecStart=/opt/kb-server/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
