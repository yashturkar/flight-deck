{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_type",
    "packet_id",
    "trace_id",
    "parent_packet_id",
    "created_at",
    "from_agent",
    "to_agent",
    "error_code",
    "error_class",
    "message",
    "retryable",
    "suggested_retry_strategy",
    "partial_artifacts",
    "metadata"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "packet_type": {"type": "string", "const": "error"},
    "packet_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "parent_packet_id": {"type": "string"},
    "created_at": {"type": "string"},
    "from_agent": {"type": "string"},
    "to_agent": {"type": "string"},
    "error_code": {"type": "string"},
    "error_class": {"enum": ["validation", "execution", "policy", "dependency", "timeout"]},
    "message": {"type": "string"},
    "retryable": {"type": "boolean"},
    "suggested_retry_strategy": {"type": "string"},
    "partial_artifacts": {"type": "array", "items": {"type": "string"}},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generated_by": {"type": "string"},
        "seed_result_packet": {"type": "string"},
        "seed_result_agent": {"type": "string"},
        "seed_result_status": {"type": "string"}
      }
    }
  }
}
