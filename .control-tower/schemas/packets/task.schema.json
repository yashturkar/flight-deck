{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_type",
    "packet_id",
    "trace_id",
    "created_at",
    "from_agent",
    "to_agent",
    "task_type",
    "priority",
    "project_id",
    "session_id",
    "title",
    "objective",
    "instructions",
    "constraints",
    "inputs",
    "expected_outputs",
    "definition_of_done",
    "memory_context_refs",
    "doc_context_refs",
    "time_budget",
    "requires_review",
    "allow_partial",
    "metadata"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "packet_type": {"type": "string", "const": "task"},
    "packet_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "parent_packet_id": {"type": ["string", "null"]},
    "created_at": {"type": "string"},
    "from_agent": {"type": "string"},
    "to_agent": {"type": "string"},
    "task_type": {"type": "string"},
    "priority": {"enum": ["low", "normal", "high", "critical"]},
    "project_id": {"type": "string"},
    "session_id": {"type": "string"},
    "title": {"type": "string"},
    "objective": {"type": "string"},
    "instructions": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "artifacts", "references"],
      "properties": {
        "files": {"type": "array", "items": {"type": "string"}},
        "artifacts": {"type": "array", "items": {"type": "string"}},
        "references": {"type": "array", "items": {"type": "string"}}
      }
    },
    "expected_outputs": {"type": "array", "items": {"type": "string"}},
    "definition_of_done": {"type": "array", "items": {"type": "string"}},
    "memory_context_refs": {"type": "array", "items": {"type": "string"}},
    "doc_context_refs": {"type": "array", "items": {"type": "string"}},
    "time_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["soft_seconds", "hard_seconds"],
      "properties": {
        "soft_seconds": {"type": "integer"},
        "hard_seconds": {"type": "integer"}
      }
    },
    "requires_review": {"type": "boolean"},
    "allow_partial": {"type": "boolean"},
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generated_by": {"type": "string"},
        "seed_result_packet": {"type": "string"},
        "seed_result_agent": {"type": "string"},
        "seed_result_status": {"type": "string"}
      }
    }
  }
}
